{
  "name": "hxrrrrri-ui",
  "version": "1.0.1",
  "description": "Ultra Luxury Glass + Ultra Minimal React component library by Harisankar S (MR.K)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:site": "vite build",
    "build:lib": "vite build --config vite.lib.config.js && tsc -p tsconfig.lib.json",
    "build:all": "npm run build:site && npm run build:lib",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib",
    "release:check": "npm run build:lib && npm pack --dry-run",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "peerDependencies": {
    "framer-motion": ">=12.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.5",
    "typescript": "^6.0.2",
    "vite": "^6.3.5"
  },
  "keywords": [
    "react",
    "ui",
    "component-library",
    "design-system",
    "framer-motion"
  ],
  "license": "MIT"
}
